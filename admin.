<script>

let accounts = JSON.parse(localStorage.getItem("accounts")) || [];

function create(){

let u = user.value.trim();
let p = pass.value.trim();
let t = parseInt(turn.value) || 1;

if(!u || !p) return alert("Nhập đủ thông tin!");

// check trùng
let exist = accounts.find(a => a.user === u);

if(exist){
  alert("Tài khoản đã tồn tại!");
  return;
}

accounts.push({
  user: u,
  pass: p,
  turns: t
});

save();
render();
clearInput();
}

// reset lượt
function addTurn(index){
accounts[index].turns += 1;
save();
render();
}

// xóa tài khoản
function removeAcc(index){
if(confirm("Xóa tài khoản này?")){
  accounts.splice(index,1);
  save();
  render();
}
}

function save(){
localStorage.setItem("accounts", JSON.stringify(accounts));
}

function clearInput(){
user.value="";
pass.value="";
turn.value="";
}

function render(){
list.innerHTML="";

accounts.forEach((a,i)=>{

list.innerHTML += `
<li>
👤 ${a.user} | 🎲 ${a.turns} lượt
<button onclick="addTurn(${i})">+1 lượt</button>
<button onclick="removeAcc(${i})">Xóa</button>
</li>
`;

});
}

render();

</script>
